<nav class="learn-nav" aria-label="{{ navAriaLabel or 'Primary' }}">
  <div class="learn-nav__pill">
    <div class="learn-nav__bar">
      <a class="learn-nav__logo" href="/">
        <span class="learn-nav__logo-mark" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2 2 7l10 5 10-5-10-5z"/>
            <path d="M2 17l10 5 10-5"/>
            <path d="M2 12l10 5 10-5"/>
          </svg>
        </span>
        <span class="learn-nav__logo-text">Mai QD</span>
      </a>
      <button type="button" class="learn-nav__toggle" aria-expanded="false" aria-controls="learn-nav-panel">
        <span class="learn-nav__toggle-icon" aria-hidden="true"></span>
        <span class="learn-nav__sr-only">Menu</span>
      </button>
      <div class="learn-nav__panel" id="learn-nav-panel">
        <ul class="learn-nav__links learn-nav__sections">
          {% if navVariant == "article" %}
            {% for link in navLinks %}
            <li>
              <a href="#{{ link.id }}" class="learn-nav__link" data-section="{{ link.id }}">{{ link.label }}</a>
            </li>
            {% endfor %}
          {% else %}
            {% for link in siteNav.links %}
            <li>
              <a
                href="{{ navPrefix }}#{{ link.id }}"
                class="learn-nav__link{% if link.id == activeSection %} is-active{% endif %}"
                {% if navPrefix == "" %}data-section="{{ link.id }}"{% endif %}
              >{{ link.label }}</a>
            </li>
            {% endfor %}
          {% endif %}
        </ul>
        <div class="learn-nav__actions">
          <a class="learn-nav__btn" href="/learn/"{% if learnActive %} aria-current="page"{% endif %}>Learn</a>
        </div>
      </div>
    </div>
  </div>
</nav>
