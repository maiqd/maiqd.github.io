    <script>
        // Full 15 Questions Database
        const quizData = [
            {
                correctIndex: 1,
                explanation: "The core layer of Clean Architecture is always the Domain containing core entities, types, and business rules, thoroughly isolated from infrastructure details.",
                points: 1
            },
            {
                correctIndex: 1, // False
                explanation: "Vertical Slice Architecture explicitly groups files by cohesive business feature workflows rather than dividing them across logical horizontal tiers.",
                points: 1
            },
            {
                correctIndex: 1, // Request-Endpoint-Response
                explanation: "REPR stands for Request-Endpoint-Response. It models an API action as a simple straight-through pipeline instead of bloated horizontal layers.",
                points: 1
            },
            {
                correctIndex: 0, // Yes
                explanation: "Steve agrees that maintaining matching interfaces for every single internal Service class is over-engineering unless required for unit testing mock instances.",
                points: 1
            },
            {
                correctIndex: 2, // Modular Monolith
                explanation: "Modular Monolith organizes cohesive features into isolated modules inside a single process, making transitions to future microservices extremely easy.",
                points: 1
            },
            {
                correctIndex: 2, // Question 6
                explanation: "Developers often generate 1-to-1 interfaces under the false belief that every single service class must be mocked or heavily abstracted.",
                points: 1
            },
            {
                correctIndex: 2, // Question 7
                explanation: "In traditional layered structures, the database acts as the architectural foundation, coupling all business logic directly to physical database schemas.",
                points: 1
            },
            {
                correctIndex: 1, // Question 8
                explanation: "The Common Closure Principle (CCP) suggests grouping classes that change together, representing the primary driving force of Vertical Slice designs.",
                points: 1
            },
            {
                correctIndex: 1, // Question 9
                explanation: "MediatR decouples API endpoints from handling execution code by sending requests through an in-process mediator container pipeline.",
                points: 1
            },
            {
                correctIndex: 2, // Question 10
                explanation: "Without strict boundary configurations, developers can accidentally link internal feature codes, degrading features into chaotic spaghetti workflows.",
                points: 1
            },
            {
                correctIndex: 1, // Question 11
                explanation: "By isolating the Core Domain from external DB concerns, you can execute comprehensive unit tests on core business logic rapidly without mock systems.",
                points: 1
            },
            {
                correctIndex: 2, // Question 12
                explanation: "To maintain strong logical separation, modules should communicate strictly via clean public interfaces or structured in-memory event buses.",
                points: 1
            },
            {
                correctIndex: 1, // Question 13
                explanation: "Architecture velocity evaluates the sustainable rate at which teams can design and deploy reliable features over the full lifespan of an application.",
                points: 1
            },
            {
                correctIndex: 1, // Question 14
                explanation: "Fusing clean principles with vertical slices shields complex Domain rules in a clean core while processing basic request flows rapidly via feature slices.",
                points: 1
            },
            {
                correctIndex: 1, // Question 15
                explanation: "Steve agrees that templated 'Clean Architecture' builds often introduce excessive project files and redundant abstractions.",
                points: 1
            }
        ];

        // State Machine
        let currentQuestionIndex = 0;
        let selectedAnswers = Array(quizData.length).fill(null);
        let completed = false;

        // Tabs
        function switchTab(tabId) {
            document.querySelectorAll('.tab-btn').forEach(btn => {
                btn.classList.remove('active');
                btn.setAttribute('aria-selected', 'false');
            });
            document.querySelectorAll('.tab-content').forEach(content => content.classList.remove('active'));
            
            event.target.classList.add('active');
            event.target.setAttribute('aria-selected', 'true');
            document.getElementById('tab-' + tabId).classList.add('active');
        }

        // YouTube IFrame Control
        function seekVideo(seconds) {
            const iframe = document.getElementById('yt-player');
            if (iframe && iframe.contentWindow) {
                iframe.contentWindow.postMessage(JSON.stringify({
                    event: 'command',
                    func: 'seekTo',
                    args: [seconds, true]
                }), '*');
                
                iframe.contentWindow.postMessage(JSON.stringify({
                    event: 'command',
                    func: 'playVideo',
                    args: []
                }), '*');
            }
        }

        // Quiz Logic
        function selectOption(questionIdx, optionIdx) {
            if (completed) return;

            selectedAnswers[questionIdx] = optionIdx;
            
            const questionElement = document.getElementById(`q-${questionIdx}`);
            const optionElements = questionElement.querySelectorAll('.option-item');
            
            optionElements.forEach((el, index) => {
                if (index === optionIdx) {
                    el.classList.add('selected');
                } else {
                    el.classList.remove('selected');
                }
            });

            showExplanation(questionIdx, optionIdx);
            updateControls();
        }

        function showExplanation(questionIdx, chosenIdx) {
            const data = quizData[questionIdx];
            const isCorrect = chosenIdx === data.correctIndex;
            const feedbackPanel = document.getElementById('feedback-panel');
            const feedbackTitle = document.getElementById('feedback-title');
            const feedbackText = document.getElementById('feedback-text');

            if (isCorrect) {
                feedbackTitle.innerHTML = `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" style="vertical-align: middle; margin-right: 6px;"><path d="M20 6 9 17l-5-5"/></svg> Harmonious Design Choice`;
                feedbackTitle.style.color = 'var(--primary)';
                feedbackText.innerText = data.explanation;
            } else {
                feedbackTitle.innerHTML = `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" style="vertical-align: middle; margin-right: 6px;"><path d="M18 6 6 18M6 6l12 12"/></svg> Architectural Friction`;
                feedbackTitle.style.color = 'var(--destructive)';
                feedbackText.innerText = `Friction detected. ${data.explanation}`;
            }

            feedbackPanel.classList.add('show');
        }

        function updateControls() {
            const prevBtn = document.getElementById('btn-prev');
            const nextBtn = document.getElementById('btn-next');
            const progressText = document.getElementById('quiz-progress-text');

            prevBtn.disabled = currentQuestionIndex === 0;
            progressText.innerText = `Question ${currentQuestionIndex + 1}/${quizData.length}`;

            if (currentQuestionIndex === quizData.length - 1) {
                nextBtn.innerHTML = '<span>Finish Checkup 🏁</span>';
            } else {
                nextBtn.innerHTML = '<span>Next →</span>';
            }
        }

        function prevQuestion() {
            if (currentQuestionIndex > 0) {
                document.getElementById(`q-${currentQuestionIndex}`).classList.remove('active');
                currentQuestionIndex--;
                document.getElementById(`q-${currentQuestionIndex}`).classList.add('active');
                
                const chosen = selectedAnswers[currentQuestionIndex];
                if (chosen !== null) {
                    showExplanation(currentQuestionIndex, chosen);
                } else {
                    document.getElementById('feedback-panel').classList.remove('show');
                }
                updateControls();
            }
        }

        function nextQuestion() {
            const currentChosen = selectedAnswers[currentQuestionIndex];
            
            if (currentChosen === null) {
                const feedbackPanel = document.getElementById('feedback-panel');
                const feedbackTitle = document.getElementById('feedback-title');
                const feedbackText = document.getElementById('feedback-text');
                
                feedbackTitle.innerHTML = `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" style="vertical-align: middle; margin-right: 6px;"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0zM12 9v4M12 17h.01"/></svg> Unfinished Blueprint`;
                feedbackTitle.style.color = 'var(--destructive)';
                feedbackText.innerText = 'Please select a design answer before proceeding with the checkup!';
                feedbackPanel.classList.add('show');
                return;
            }

            if (currentQuestionIndex < quizData.length - 1) {
                document.getElementById(`q-${currentQuestionIndex}`).classList.remove('active');
                currentQuestionIndex++;
                document.getElementById(`q-${currentQuestionIndex}`).classList.add('active');
                
                const chosen = selectedAnswers[currentQuestionIndex];
                if (chosen !== null) {
                    showExplanation(currentQuestionIndex, chosen);
                } else {
                    document.getElementById('feedback-panel').classList.remove('show');
                }
                updateControls();
            } else {
                calculateFinalAssessment();
            }
        }

        function calculateFinalAssessment() {
            let score = 0;
            quizData.forEach((question, index) => {
                if (selectedAnswers[index] === question.correctIndex) {
                    score++;
                }
            });

            document.getElementById('quiz-container').style.display = 'none';
            const resultsContainer = document.getElementById('results-container');
            resultsContainer.classList.add('active');

            document.getElementById('final-score').innerText = `${score}/${quizData.length}`;

            const commentaryEl = document.getElementById('score-commentary');
            if (score === quizData.length) {
                commentaryEl.innerText = "🏆 Perfect Structural Integrity! Your design patterns represent flawless architecture coordination.";
            } else if (score >= 10) {
                commentaryEl.innerText = "💡 Solid Foundation. You understand where decoupled boundaries are appropriate, and when to opt for feature speed.";
            } else {
                commentaryEl.innerText = "🏺 Study Phase. We recommend reviewing the checkpoints and studying Steve Smith's interface criteria.";
            }

            completed = true;
        }

        function resetQuiz() {
            currentQuestionIndex = 0;
            selectedAnswers = Array(quizData.length).fill(null);
            completed = false;

            document.getElementById('quiz-container').style.display = 'block';
            document.getElementById('results-container').classList.remove('active');
            document.getElementById('feedback-panel').classList.remove('show');

            document.querySelectorAll('.option-item').forEach(el => {
                el.classList.remove('selected', 'correct', 'incorrect');
            });

            document.querySelectorAll('.question-box').forEach((box, index) => {
                if (index === 0) box.classList.add('active');
                else box.classList.remove('active');
            });

            updateControls();
        }
    </script>
